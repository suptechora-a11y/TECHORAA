<nav class="site-nav">
  <a href="/" class="logo">{{ section.settings.logo_text | default: shop.name | upcase }}</a>
  <ul class="nav-links">
    {% for link in linklists.main-menu.links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
    {% endfor %}
  </ul>
  <div class="nav-right">
    <a href="/cart" class="cart-btn">🛒 Cart ({{ cart.item_count }})</a>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "TECHORA" }
  ]
}
{% endschema %}

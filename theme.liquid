<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  {{ 'techora.css' | asset_url | stylesheet_tag }}
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

{% section 'header' %}

<main role="main">
  {{ content_for_layout }}
</main>

{% section 'footer' %}

<div class="toast" id="toast"></div>

{{ 'techora.js' | asset_url | script_tag }}
</body>
</html>
